# ──────────────────────────────────────────
# 항공 유류할증료 파이프라인 환경변수
# 이 파일을 복사해 .env.local 로 저장 후 값을 채우세요.
# .env.local은 .gitignore에 반드시 포함할 것.
# ──────────────────────────────────────────

# [필수] Anthropic API 키
# 용도: lib/parser/index.js — 공지 텍스트 → JSON 구조화
# 없으면: mock 파서로 자동 fallback (파이프라인 중단 없음)
# 발급: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# [선택] exchangerate-api.com 환율 API 키
# 용도: lib/market/index.js — USD/KRW, USD/JPY 실시간 환율
# 없으면: mock 환율값 사용 (USD/KRW=1480, USD/JPY=149.2)
# 발급: https://www.exchangerate-api.com/ (무료 플랜: 월 1,500회)
EXCHANGERATE_API_KEY=

# [선택] 실시간 시장 데이터 사용 여부
# "true" 설정 시: EXCHANGERATE_API_KEY로 환율 실제 호출
# 미설정 or "false": 항상 mock 데이터 사용
# 주의: --mock 플래그 사용 시 이 설정 무시하고 항상 mock
USE_LIVE_MARKET_DATA=false

# [미구현] EIA Jet Fuel API 키 (향후 확장용)
# 현재는 mock 고정. 구현 시 lib/market/index.js fetchJetFuelPrice() 채울 것.
# EIA_API_KEY=
